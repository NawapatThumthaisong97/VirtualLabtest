#cp ไฟล์นี้เป็น group_vars/all.yml แล้วกรอกค่าจริง  ห้าม commit all.yml ตัวจริงเข้า git เด็ดขาด 
#เพราะในนี้ มี credentials ที่สามารถ expose ไปที่ภายนอกได้ หากเผลอทําให้ revoke credential นั้น

# --- K3s ---
k3s_version: v1.35.5+k3s1
k3s_api_port: 6443

# --- Network (ระวังชนกับ LAN / AWS VPC) ---
k3s_cluster_cidr: 10.42.0.0/16
k3s_service_cidr: 10.43.0.0/16
flannel_iface: tailscale0

# --- Cloudflare Tunnel ---
# สร้าง tunnel + token ใหม่จาก Cloudflare Zero Trust dashboard (Networks -> Tunnels)
cloudflare_tunnel_token: <CLOUDFLARE_TUNNEL_TOKEN>

# --- SkyPilot ---
skypilot_domain: <SKYPILOT_DOMAIN>   # e.g. skypilot.yourdomain.com

# ต้องเป็น stable chart เท่านั้น (ห้าม nightly) - หาเลขล่าสุดด้วย
# สามารถตรวจสอบได้จาก `helm search repo skypilot/skypilot --versions` แล้วเอาตัวบนสุดที่ไม่มี rc/dev/nightly ต่อท้าย

skypilot_chart_version: "<SKYPILOT_CHART_VERSION>"   # ณ ตอนนี้แนะนําให้ลง 0.12.3+post.1 เราใช้ตัวนี้อยู่

# --- Optional: skypilot-node role ---
# ปกติ role ไม่ลบ namespace skypilot เดิมทิ้ง (idempotent) จะรีเซ็ตแบบลบทิ้งแล้วลงใหม่ได้ก็ต่อเมื่อ
# รันด้วย: ansible-playbook site.yml --tags skypilot-node -e skypilot_reset=true
# skypilot_reset: false

#วิธีเรียกใช้งาน
#เวลารันให้เรียกคําสั่ง ansible-playbook -i inventory.yml site.yml -K
#หากต้องการดูว่าสิ่งที่เราต้องทํามีอะไรบ้าง ansible-playbook -i inventory.yml site.yml --list-tasks
#หากต้องการดูว่าเราพร้อมรันยังให้ดู ansible-playbook -i inventory.yml site.yml --check -K