# Terraform state files — never commit (contain plaintext secrets)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files with real values — never commit
terraform.tfvars
*.auto.tfvars

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Override files (local overrides, not for sharing)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated plan files
*.tfplan
