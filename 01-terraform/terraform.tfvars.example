###############################################################################
# terraform.tfvars.example
#
# Copy this to terraform.tfvars and fill in the values.
# ⚠️  NEVER commit terraform.tfvars to git — it contains the Tailscale auth key!
#     terraform.tfvars is already in .gitignore.
###############################################################################

aws_region          = "ap-southeast-1"
environment         = "poc"

vpc_cidr            = "10.0.0.0/16"
public_subnet_cidr  = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"
avvirtuallability_zone   = "ap-southeast-1a"

# Get from: https://login.tailscale.com/admin/settings/keys
# Create a Reusable, Ephemeral key with tag: tag:virtuallab-gateway
tailscale_auth_key  = "tskey-auth-REPLACE_ME"

# Leave empty to disable key pair (use Tailscale SSH instead)
gateway_key_pair_name = ""

ml_bucket_name      = "virtuallab-ml-artifacts"
iam_user_name       = "virtuallab-skypilot"
