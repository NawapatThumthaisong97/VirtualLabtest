################################################################################
# credentials.env.example — Template สำหรับ AI Learner Lab
#
# วิธีใช้:
#   1. Copy ไฟล์นี้:   cp credentials.env.example credentials.env
#   2. แก้ค่าใน credentials.env ให้ครบทุกช่อง (ห้ามแก้ไฟล์นี้!)
#   3. ไม่ต้องแตะไฟล์อื่นอีกเลย — deploy.sh จะอ่านจาก credentials.env อัตโนมัติ
#
# ⚠️  NEVER commit credentials.env ลง git!
#     (ไฟล์นี้อยู่ใน .gitignore อยู่แล้ว)
#     ไฟล์นี้ (credentials.env.example) ปลอดภัยที่จะ commit เพราะไม่มี secret จริง
################################################################################


# ══════════════════════════════════════════════════════════════════════════════
# 🔑  AWS Credentials
# ดูได้ที่: AWS Console → IAM → Users → virtuallab-skypilot → Security credentials
# ══════════════════════════════════════════════════════════════════════════════

AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AWS_DEFAULT_REGION="ap-southeast-1"


# ══════════════════════════════════════════════════════════════════════════════
# 🌐  Tailscale
# สร้าง Reusable Auth Key ที่: https://login.tailscale.com/admin/settings/keys
# ✅ ติ๊ก "Reusable" และ "Ephemeral" พร้อมใส่ tag: tag:virtuallab-gateway
# รูปแบบ key จะขึ้นต้นด้วย tskey-auth-
# ══════════════════════════════════════════════════════════════════════════════

TAILSCALE_AUTH_KEY="tskey-auth-kEXAMPLE000CNTRL-exampleAuthKeyString"


# ══════════════════════════════════════════════════════════════════════════════
# ☁️  Cloudflare Tunnel
# สร้าง Tunnel ที่: https://one.dash.cloudflare.com → Networks → Tunnels
# 1. สร้าง Tunnel ใหม่ → เลือก "Cloudflared" → Copy token ที่ได้
# 2. ตั้งชื่อ Public Hostname (เช่น virtuallab.yourdomain.com) แล้วชี้ไปที่ http://nginx-ingress:80
# ══════════════════════════════════════════════════════════════════════════════

CLOUDFLARE_TUNNEL_TOKEN="eyJhIjoiZXhhbXBsZUFjY291bnRJZCIsInQiOiJleGFtcGxlVHVubmVsSWQiLCJzIjoiZXhhbXBsZVNlY3JldEtleT0ifQ=="
# โดเมน Public ที่ตั้งใน Cloudflare Tunnel (ใช้สำหรับ OAuth2 redirect URL)
CLOUDFLARE_TUNNEL_DOMAIN="virtuallab.yourdomain.com"


# ══════════════════════════════════════════════════════════════════════════════
# 🔵  Google OAuth (สำหรับ oauth2-proxy)
# สร้างที่: https://console.cloud.google.com → APIs & Services → Credentials
# → Create Credentials → OAuth 2.0 Client IDs → Web application
# Authorized redirect URIs: https://virtuallab.yourdomain.com/oauth2/callback
# ══════════════════════════════════════════════════════════════════════════════

GOOGLE_CLIENT_ID="123456789012-exampleclientid.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-exampleGoogleOAuthClientSecret"
OAUTH2_COOKIE_SECRET="examplecookiesecret1234567890ab"
# สร้าง cookie secret (32 chars): python3 -c "import secrets; print(secrets.token_hex(16))"


# ══════════════════════════════════════════════════════════════════════════════
# 🐘  PostgreSQL
# ══════════════════════════════════════════════════════════════════════════════

POSTGRES_USER="virtuallab"
POSTGRES_PASSWORD="change-me-use-a-strong-password-here"
POSTGRES_DB="virtuallab_db"
# DATABASE_URL ใช้ค่าจากตัวแปรด้านบน — อย่าแก้บรรทัดนี้
DATABASE_URL="postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"


# ══════════════════════════════════════════════════════════════════════════════
# 📦  S3 / Terraform Config
# ══════════════════════════════════════════════════════════════════════════════

ML_BUCKET_NAME="virtuallab-ml-artifacts"
TF_STATE_BUCKET="virtuallab-tfstate"      # ถ้าใช้ S3 backend ใน Terraform


# ══════════════════════════════════════════════════════════════════════════════
# 🏠  On-Prem / K3s
# ══════════════════════════════════════════════════════════════════════════════

K3S_MASTER_IP="192.168.1.100"        # IP จริงของ K3s Master Node (on-prem)
KUBECONFIG_PATH="$HOME/.kube/config" # Path ของ kubeconfig


# ══════════════════════════════════════════════════════════════════════════════
# 🔧  Terraform Variables (ส่งอัตโนมัติผ่าน TF_VAR_* prefix)
# ══════════════════════════════════════════════════════════════════════════════

TF_VAR_tailscale_auth_key="$TAILSCALE_AUTH_KEY"
TF_VAR_aws_region="$AWS_DEFAULT_REGION"
TF_VAR_ml_bucket_name="$ML_BUCKET_NAME"
