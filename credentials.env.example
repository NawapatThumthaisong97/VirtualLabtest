################################################################################
# credentials.env — ไฟล์รวม Credential ทั้งหมดของ AI Learner Lab
#
# วิธีใช้:
#   1. Copy ไฟล์นี้:   cp credentials.env.example credentials.env
#   2. แก้ค่าด้านล่างให้ครบ
#   3. ไม่ต้องแตะไฟล์อื่นอีกเลย — setup.sh และ scripts ต่างๆ จะอ่านจากที่นี่อัตโนมัติ
#
# ⚠️  NEVER commit credentials.env ลง git!
#     (ไฟล์นี้อยู่ใน .gitignore อยู่แล้ว)
################################################################################


# ══════════════════════════════════════════════════════════════════════════════
# 🔑  AWS Credentials
# ดูได้ที่: AWS Console → IAM → Users → ailab-skypilot → Security credentials
# ══════════════════════════════════════════════════════════════════════════════

AWS_ACCESS_KEY_ID="AKIA_REPLACE_ME"
AWS_SECRET_ACCESS_KEY="REPLACE_ME_SECRET"
AWS_DEFAULT_REGION="ap-southeast-1"


# ══════════════════════════════════════════════════════════════════════════════
# 🌐  Tailscale
# สร้าง Reusable Auth Key ที่: https://login.tailscale.com/admin/settings/keys
# ✅ ติ๊ก "Reusable" และ "Ephemeral" พร้อมใส่ tag: tag:ailab-gateway
# ══════════════════════════════════════════════════════════════════════════════

TAILSCALE_AUTH_KEY="tskey-auth-REPLACE_ME"


# ══════════════════════════════════════════════════════════════════════════════
# ☁️  Cloudflare Tunnel
# สร้าง Tunnel ที่: https://one.dash.cloudflare.com → Networks → Tunnels
# ══════════════════════════════════════════════════════════════════════════════

CLOUDFLARE_TUNNEL_TOKEN="REPLACE_ME_CLOUDFLARE_TOKEN"


# ══════════════════════════════════════════════════════════════════════════════
# 🔵  Google OAuth (สำหรับ oauth2-proxy)
# สร้างที่: https://console.cloud.google.com → APIs & Services → Credentials
# ══════════════════════════════════════════════════════════════════════════════

GOOGLE_CLIENT_ID="REPLACE_ME.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="REPLACE_ME_GOOGLE_SECRET"
OAUTH2_COOKIE_SECRET="REPLACE_ME_32_CHAR_RANDOM_STRING"
# สร้าง cookie secret: python3 -c "import secrets; print(secrets.token_hex(16))"


# ══════════════════════════════════════════════════════════════════════════════
# 🐘  PostgreSQL
# ══════════════════════════════════════════════════════════════════════════════

POSTGRES_USER="ailab"
POSTGRES_PASSWORD="REPLACE_ME_STRONG_PASSWORD"
POSTGRES_DB="ailab_db"
DATABASE_URL="postgresql+asyncpg://ailab:REPLACE_ME_STRONG_PASSWORD@localhost:5432/ailab_db"


# ══════════════════════════════════════════════════════════════════════════════
# 📦  S3 / Terraform Config (ถ้าใช้ Remote State)
# ══════════════════════════════════════════════════════════════════════════════

ML_BUCKET_NAME="ailab-ml-artifacts"
TF_STATE_BUCKET="ailab-tfstate"      # ถ้าใช้ S3 backend ใน Terraform


# ══════════════════════════════════════════════════════════════════════════════
# 🏠  On-Prem / K3s
# ══════════════════════════════════════════════════════════════════════════════

K3S_MASTER_IP="192.168.x.x"          # IP ของ K3s Master Node (on-prem)
KUBECONFIG_PATH="$HOME/.kube/config"  # Path ของ kubeconfig


# ══════════════════════════════════════════════════════════════════════════════
# 🔧  Terraform Variables (ส่งอัตโนมัติผ่าน TF_VAR_* prefix)
# ══════════════════════════════════════════════════════════════════════════════

TF_VAR_tailscale_auth_key="$TAILSCALE_AUTH_KEY"
TF_VAR_aws_region="$AWS_DEFAULT_REGION"
TF_VAR_ml_bucket_name="$ML_BUCKET_NAME"
