################################################################################
# credentials.env.example — VirtualLab POC Credentials Template
#
# วิธีใช้:
#   1. cp credentials.env.example credentials.env
#   2. แก้ค่าใน credentials.env ให้ครบทุกช่อง
#   3. ไฟล์นี้ปลอดภัยที่จะ commit (ไม่มี secret จริง)
################################################################################

# ══════════════════════════════════════════════════════════════════════════════
# 🔑  AWS Credentials
# ══════════════════════════════════════════════════════════════════════════════

AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AWS_DEFAULT_REGION="ap-southeast-1"

# ══════════════════════════════════════════════════════════════════════════════
# 🌐  Tailscale
# สร้างที่: https://login.tailscale.com/admin/settings/keys
# ══════════════════════════════════════════════════════════════════════════════

TAILSCALE_AUTH_KEY="tskey-auth-kEXAMPLE000CNTRL-exampleAuthKeyString"
K3S_ONPREM_CIDR="192.168.1.0/24"   # CIDR จริงของ on-prem network

# ══════════════════════════════════════════════════════════════════════════════
# 🏠  K3s (On-Prem) — กรอกหลังรัน 02-k3s/install-master.sh
# ══════════════════════════════════════════════════════════════════════════════

K3S_MASTER_IP="192.168.1.100"
K3S_NODE_TOKEN="K10exampleNodeTokenFromMasterNode::server:examplehash"
KUBECONFIG_PATH="$HOME/.kube/config"

# ══════════════════════════════════════════════════════════════════════════════
# 📦  S3
# ══════════════════════════════════════════════════════════════════════════════

ML_BUCKET_NAME="virtuallab-ml-artifacts"

# ══════════════════════════════════════════════════════════════════════════════
# 🔧  Terraform Variables
# ══════════════════════════════════════════════════════════════════════════════

TF_VAR_tailscale_auth_key="$TAILSCALE_AUTH_KEY"
TF_VAR_aws_region="$AWS_DEFAULT_REGION"
TF_VAR_ml_bucket_name="$ML_BUCKET_NAME"
