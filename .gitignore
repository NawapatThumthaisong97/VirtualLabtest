*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# -----------------------------------------------------------------------------
# ­¤ō” Docker
# -----------------------------------------------------------------------------
# Don't ignore Dockerfiles, but ignore local build artifacts
.dockerignore
# ^^ Don't ignore .dockerignore itself ŌĆö it belongs in the repo

# Local docker-compose overrides with secrets
docker-compose.override.yml
docker-compose.local.yml

