# Application
APP_NAME=FastAPI Backend
APP_VERSION=1.0.0
DEBUG=True
API_PREFIX=/api

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/virtual_lab

# Security
SECRET_KEY=your-secret-key-change-this-in-production-use-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated, no spaces around comma)
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:5173

# Cloudflare R2
R2_ACCOUNT_ID=
R2_BUCKET_NAME=virtual-lab-images
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# Redis (Optional)
REDIS_URL=redis://localhost:6379/0